{
    "latex-workshop.latex.recipes": [
        {
            "name": "Compila (LuaLaTeX)",
            "tools": [
                "latexmk-lua"
            ]
        }
    ],
    "latex-workshop.formatting.latex": "latexindent",
    "latex-workshop.synctex.afterBuild.enabled": true,
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk-lua",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "-pdflua",
                "%DOC%"
            ]
        }
    ],
    "ltex.language": "it",
    "ltex.additionalRules.motherTongue": "it",
    "ltex.additionalRules.enablePickyRules": true,
    "ltex.checkFrequency": "edit",
    "ltex.enabled": [
        "latex"
    ],
    "ltex.latex.commands": {
        "\\sethlcolor{}": "ignore",
        "\\usetheme{}": "ignore",
        "\\usefonttheme[]{}": "ignore",
        "\\titlebackground*{}": "ignore",
        "\\footlinecolor{}": "ignore",
        "\\newlist{}{}{}": "ignore",
        "\\DeclareRobustCommand{}[]{}": "ignore",
        "\\DeclareRobustCommand{}{}": "ignore",
        "\\algnewcommand{}[]{}": "ignore",
        "\\algnewcommand{}{}": "ignore",
        "\\texttt{}": "dummy",
        "\\gls{}": "dummy",
        "\\glspl{}": "dummy",
        "\\glsentrytext{}": "dummy",
        "\\newacronym{}{}{}": "ignore",
        "\\label{}": "ignore",
        "\\ref{}": "ignore",
        "\\cite{}": "ignore",
        "\\autoref{}": "ignore",
        "\\emph{}": "dummy",
        "\\textbf{}": "dummy",
        "\\textit{}": "dummy",
        "\\section{}": "dummy",
        "\\subsection{}": "dummy",
        "\\chapter{}": "dummy"
    },
    "ltex.disabledRules": {
        "it": [
            "ST_01_005",
            "ER_01_001",
            "ER_02_004",
            "WHITESPACE_RULE",
            "COMMA_PARENTHESIS_WHITESPACE",
            "WHITESPACE_PUNCTUATION",
            "DOUBLE_PUNCTUATION",
            "UPPERCASE_SENTENCE_START",
            "GR_10_003"
        ]
